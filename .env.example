# ── Server ──────────────────────────────────────────────────────────────────
# Port the Go backend listens on (default: :8080)
SERVER_ADDRESS=:8080

# ── Database ─────────────────────────────────────────────────────────────────
# For local Docker Compose the host must be 'postgres' (the service name).
# For a local non-Docker run use 'localhost'.
DATABASE_URL=postgres://signalstack:signalstack@postgres:5432/signalstack?sslmode=disable
POSTGRES_USER=signalstack
POSTGRES_PASSWORD=signalstack
POSTGRES_DB=signalstack

# ── Auth ─────────────────────────────────────────────────────────────────────
# Must be a long random string in production.
JWT_SECRET=change-me

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# Leave OPENAI_API_KEY empty to use the deterministic fallback embedder.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── AWS (optional) ────────────────────────────────────────────────────────────
# Leave empty to skip S3 raw-payload uploads (ingestion still works locally).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=signalstack-raw-responses

# ── API Keys ──────────────────────────────────────────────────────────────────
# The Guardian requires a free key (https://open-platform.theguardian.com/).
# All other adapters use public, keyless endpoints.
GUARDIAN_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the Vue app uses to reach the backend API.
# In Docker Compose the frontend container proxies to the backend service.
VITE_API_BASE_URL=http://localhost:8080
